{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mappable-records1.schema.json",
  "title": "Mappable Records Run 1",
  "description": "The 30 largest operating U.S. Marriott portfolio hotels, ranked by published guest-room count.",
  "type": "array",
  "minItems": 30,
  "maxItems": 30,
  "items": {
    "type": "object",
    "required": ["rank", "title", "brand", "location", "value", "size", "nightly_price", "building", "history", "sources", "verified_at"],
    "additionalProperties": false,
    "properties": {
      "rank": { "type": "integer", "minimum": 1, "maximum": 30 },
      "title": { "type": "string", "minLength": 1 },
      "brand": { "type": "string", "minLength": 1 },
      "location": {
        "type": "object",
        "required": ["address", "city", "state", "postal_code", "coordinates"],
        "additionalProperties": false,
        "properties": {
          "address": { "type": "string", "minLength": 1 },
          "city": { "type": "string", "minLength": 1 },
          "state": { "type": "string", "pattern": "^[A-Z]{2}$" },
          "postal_code": { "type": "string", "minLength": 5 },
          "coordinates": {
            "type": "object",
            "required": ["lat", "lng"],
            "additionalProperties": false,
            "properties": {
              "lat": { "type": "number", "minimum": -90, "maximum": 90 },
              "lng": { "type": "number", "minimum": -180, "maximum": 180 }
            }
          }
        }
      },
      "value": { "type": "string", "pattern": "^[0-9]{1,3}(,[0-9]{3})* rooms$" },
      "size": {
        "type": "object",
        "required": ["total_guest_rooms", "ranking_metric"],
        "additionalProperties": false,
        "properties": {
          "total_guest_rooms": { "type": "integer", "minimum": 1 },
          "suites": { "type": ["integer", "null"], "minimum": 0 },
          "ranking_metric": { "const": "total_guest_rooms" }
        }
      },
      "nightly_price": {
        "type": ["object", "null"],
        "required": ["low", "high", "currency", "taxes_included", "stay_dates", "occupancy", "observed_at"],
        "additionalProperties": false,
        "properties": {
          "low": { "type": "number", "minimum": 0 },
          "high": { "type": "number", "minimum": 0 },
          "currency": { "const": "USD" },
          "taxes_included": { "type": "boolean" },
          "stay_dates": { "type": "string", "minLength": 1 },
          "occupancy": { "type": "string", "minLength": 1 },
          "observed_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      },
      "building": {
        "type": "object",
        "required": ["floors", "year_opened", "year_built", "last_renovated", "building_square_feet", "meeting_space_square_feet"],
        "additionalProperties": false,
        "properties": {
          "floors": { "type": ["integer", "null"], "minimum": 1 },
          "year_opened": { "type": ["integer", "null"], "minimum": 1800, "maximum": 2026 },
          "year_built": { "type": ["integer", "null"], "minimum": 1800, "maximum": 2026 },
          "last_renovated": { "type": ["integer", "null"], "minimum": 1800, "maximum": 2026 },
          "building_square_feet": { "type": ["integer", "null"], "minimum": 1 },
          "meeting_space_square_feet": { "type": ["integer", "null"], "minimum": 0 }
        }
      },
      "history": {
        "type": "array",
        "items": { "type": "string", "minLength": 1 }
      },
      "sources": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["url", "publisher", "supports", "verified_at"],
          "additionalProperties": false,
          "properties": {
            "url": { "type": "string", "format": "uri" },
            "publisher": { "type": "string", "minLength": 1 },
            "supports": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "note": { "type": "string" },
            "verified_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
          }
        }
      },
      "verified_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
    }
  }
}
