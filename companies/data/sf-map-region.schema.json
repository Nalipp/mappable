{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sf-map-region.schema.json",
  "title": "San Francisco Map Region",
  "description": "Static map geometry contract for the local Mappable San Francisco basemap.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "source_dataset",
    "bounds",
    "view_box",
    "basemap"
  ],
  "properties": {
    "version": {
      "const": 1
    },
    "source_dataset": {
      "const": "data/mappable-records1.json"
    },
    "bounds": {
      "type": "object",
      "additionalProperties": false,
      "required": ["north", "south", "west", "east"],
      "properties": {
        "north": { "type": "number", "const": 37.84 },
        "south": { "type": "number", "const": 37.7 },
        "west": { "type": "number", "const": -122.53 },
        "east": { "type": "number", "const": -122.35 }
      }
    },
    "view_box": {
      "type": "object",
      "additionalProperties": false,
      "required": ["min_x", "min_y", "width", "height"],
      "properties": {
        "min_x": { "type": "number", "const": 0 },
        "min_y": { "type": "number", "const": 0 },
        "width": { "type": "number", "const": 1000 },
        "height": { "type": "number", "const": 760 }
      }
    },
    "basemap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["asset", "source", "license", "attribution", "geometry", "generated_at"],
      "properties": {
        "asset": {
          "const": "HTML/shadcn/assets/san-francisco-basemap.svg"
        },
        "source": {
          "const": "OpenStreetMap"
        },
        "license": {
          "const": "ODbL"
        },
        "attribution": {
          "const": "© OpenStreetMap contributors"
        },
        "geometry": {
          "type": "array",
          "items": {
            "enum": ["coastline", "motorway", "trunk", "primary"]
          },
          "minItems": 4,
          "maxItems": 4,
          "uniqueItems": true
        },
        "generated_at": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      }
    }
  }
}
