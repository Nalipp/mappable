{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "candidates.schema.json",
  "title": "Discovery Candidates",
  "type": "object",
  "required": ["metadata", "candidates"],
  "additionalProperties": false,
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["generated_at", "source", "version"],
      "additionalProperties": false,
      "properties": {
        "generated_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
        "source": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "discovery_signals", "notes"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "discovery_signals": {
            "type": "object",
            "additionalProperties": { "type": ["string", "null"] }
          },
          "notes": { "type": ["string", "null"] }
        }
      }
    }
  }
}
