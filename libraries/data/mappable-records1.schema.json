{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "mappable-records1.schema.json",
  "title": "30 Largest U.S. Central Public-Library Buildings",
  "description": "FY 2024 IMLS central public-library outlets ranked by reported outlet floor area. Building and system measurements are deliberately separated by scope.",
  "type": "array",
  "minItems": 30,
  "maxItems": 30,
  "items": { "$ref": "#/$defs/record" },
  "$defs": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "record": {
      "type": "object",
      "required": [
        "rank",
        "title",
        "value",
        "location",
        "library",
        "ranking",
        "building",
        "system_statistics",
        "sources",
        "verified_at"
      ],
      "additionalProperties": false,
      "properties": {
        "rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 30
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "pattern": "^[0-9,]+ sq ft$"
        },
        "location": {
          "type": "object",
          "required": [
            "address",
            "city",
            "state",
            "postal_code",
            "county",
            "coordinates",
            "geocode"
          ],
          "additionalProperties": false,
          "properties": {
            "address": { "type": "string", "minLength": 1 },
            "city": { "type": "string", "minLength": 1 },
            "state": { "type": "string", "pattern": "^[A-Z]{2}$" },
            "postal_code": { "type": "string", "pattern": "^\\d{5}(-\\d{4})?$" },
            "county": { "type": "string", "minLength": 1 },
            "coordinates": {
              "type": "object",
              "required": ["lat", "lng"],
              "additionalProperties": false,
              "properties": {
                "lat": { "type": "number", "minimum": -90, "maximum": 90 },
                "lng": { "type": "number", "minimum": -180, "maximum": 180 }
              }
            },
            "geocode": {
              "type": "object",
              "required": ["provider", "crs", "status", "score", "match_type"],
              "additionalProperties": false,
              "properties": {
                "provider": { "const": "Esri World Geocoder via IMLS" },
                "crs": { "const": "WGS84/EPSG:4326" },
                "status": { "enum": ["E", "T"] },
                "score": { "type": "number", "minimum": 90, "maximum": 100 },
                "match_type": { "type": "string", "minLength": 1 }
              }
            }
          }
        },
        "library": {
          "type": "object",
          "required": [
            "outlet_id",
            "system_id",
            "system_name",
            "outlet_type",
            "library_type"
          ],
          "additionalProperties": false,
          "properties": {
            "outlet_id": { "type": "string", "minLength": 1 },
            "system_id": { "type": "string", "minLength": 1 },
            "system_name": { "type": "string", "minLength": 1 },
            "outlet_type": { "const": "central" },
            "library_type": { "const": "public" }
          }
        },
        "ranking": {
          "type": "object",
          "required": [
            "metric",
            "value",
            "unit",
            "reporting_year",
            "scope",
            "definition"
          ],
          "additionalProperties": false,
          "properties": {
            "metric": { "const": "reported_outlet_floor_area" },
            "value": { "type": "integer", "minimum": 1 },
            "unit": { "const": "sq_ft" },
            "reporting_year": { "const": 2024 },
            "scope": { "const": "building" },
            "definition": { "type": "string", "minLength": 1 }
          }
        },
        "building": {
          "type": "object",
          "required": ["reported_square_feet", "square_feet_flag"],
          "additionalProperties": false,
          "properties": {
            "reported_square_feet": { "type": "integer", "minimum": 1 },
            "square_feet_flag": { "type": "string", "minLength": 1 },
            "annual_public_service_hours": { "type": "integer", "minimum": 0 },
            "public_service_hours_flag": { "type": "string", "minLength": 1 },
            "weeks_open": { "type": "integer", "minimum": 0 },
            "weeks_open_flag": { "type": "string", "minLength": 1 },
            "opened_year": { "type": "integer", "minimum": 1600, "maximum": 2026 },
            "architects": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "history_summary": { "type": "string", "minLength": 1 }
          }
        },
        "system_statistics": {
          "type": "object",
          "required": ["scope", "reporting_period", "outlet_counts", "data_flags"],
          "additionalProperties": false,
          "properties": {
            "scope": { "const": "library_system" },
            "reporting_period": {
              "type": "object",
              "required": ["start", "end"],
              "additionalProperties": false,
              "properties": {
                "start": { "type": "string", "pattern": "^\\d{2}/\\d{2}/\\d{4}$" },
                "end": { "type": "string", "pattern": "^\\d{2}/\\d{2}/\\d{4}$" }
              }
            },
            "outlet_counts": {
              "type": "object",
              "required": ["central_libraries", "branch_libraries"],
              "additionalProperties": false,
              "properties": {
                "central_libraries": { "type": "integer", "minimum": 0 },
                "branch_libraries": { "type": "integer", "minimum": 0 }
              }
            },
            "legal_service_area_population": { "type": "integer", "minimum": 0 },
            "registered_users": { "type": "integer", "minimum": 0 },
            "print_materials": { "type": "integer", "minimum": 0 },
            "total_physical_items": { "type": "integer", "minimum": 0 },
            "annual_visits": { "type": "integer", "minimum": 0 },
            "visits_reporting_method": { "enum": ["CT", "ES", "M"] },
            "annual_circulation": { "type": "integer", "minimum": 0 },
            "physical_circulation": { "type": "integer", "minimum": 0 },
            "data_flags": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "legal_service_area_population": { "type": "string", "minLength": 1 },
                "registered_users": { "type": "string", "minLength": 1 },
                "print_materials": { "type": "string", "minLength": 1 },
                "total_physical_items": { "type": "string", "minLength": 1 },
                "annual_visits": { "type": "string", "minLength": 1 },
                "annual_circulation": { "type": "string", "minLength": 1 },
                "physical_circulation": { "type": "string", "minLength": 1 },
                "central_libraries": { "type": "string", "minLength": 1 },
                "branch_libraries": { "type": "string", "minLength": 1 }
              }
            },
            "notes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "sources": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["url", "scope", "note", "verified_at"],
            "additionalProperties": false,
            "properties": {
              "url": { "type": "string", "format": "uri" },
              "scope": {
                "enum": [
                  "ranking_building_and_system_data",
                  "definitions_and_geocoding_method",
                  "building_history"
                ]
              },
              "note": { "type": "string", "minLength": 1 },
              "verified_at": { "$ref": "#/$defs/date" }
            }
          }
        },
        "verified_at": { "$ref": "#/$defs/date" }
      }
    }
  }
}
