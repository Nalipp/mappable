{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "candidate-validation.schema.json",
  "title": "Candidate Validation",
  "type": "object",
  "required": ["profile", "candidates"],
  "additionalProperties": false,
  "properties": {
    "profile": { "type": "string" },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["candidate", "status", "checks"],
        "additionalProperties": false,
        "properties": {
          "candidate": { "type": "string", "minLength": 1 },
          "status": { "enum": ["validated", "needs_verification", "rejected"] },
          "checks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["constraint", "result", "evidence", "verified_at"],
              "additionalProperties": false,
              "properties": {
                "constraint": { "type": "string" },
                "result": { "enum": ["pass", "fail", "unverified"] },
                "url": { "type": "string", "format": "uri" },
                "evidence": { "type": "string", "minLength": 1 },
                "verified_at": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
              },
              "allOf": [{
                "if": { "properties": { "result": { "enum": ["pass", "fail"] } } },
                "then": { "required": ["url"] }
              }]
            }
          },
          "failed_constraint": { "type": "string" },
          "final_record": {
            "$ref": "mappable-records1.schema.json#/items",
            "description": "Complete facts captured during validation for local-only finalization."
          },
          "notes": { "type": "string" }
        },
        "allOf": [{
          "if": { "properties": { "status": { "const": "rejected" } } },
          "then": { "required": ["failed_constraint"] }
        }, {
          "if": { "properties": { "status": { "const": "validated" } } },
          "then": {
            "required": ["final_record"],
            "properties": {
              "checks": {
                "minItems": 5,
                "items": { "properties": { "result": { "const": "pass" } } }
              }
            }
          }
        }]
      }
    }
  }
}
